# msmtp Konfiguration - STARK VERSCHLÜSSELT (TLS-Tunnel)
defaults
auth           on
tls            on
# STARTTLS deaktiviert, um den TLS-Tunnel auf Port 465 zu erzwingen
tls_starttls   off
tls_certcheck  on
logfile        ~/.msmtp.log

# Strato Account
account        strato
host           smtp.strato.de
port           465
from           DEINE_EMAIL_ADRESSE
user           DEIN_BENUTZERNAME
password       DEIN_PASSWORT

# Setze Strato als Standard
account default : strato
#EOF
